{
    "flow_name": "AI Greeting Transletor with Cost Prediction",
    "nodes": [
        {
            "id": "cost_predictor",
            "type": "CostPredictNode",
            "params":{
                "w": [0.0, 0.0],
                "b": 0.0
            }
        },
        {
            "id": "router",
            "type": "RouterNode",
            "params": {}
        },
        {
            "id": "reader",
            "type": "FileReadNode",
            "params": {
                "file_path": "my_info.txt"
        }},
        {
            "id": "llm",
            "type": "LLMNode",
            "params": {
                "model": "gpt-4o-mini",
                "system_prompt": "You are the professional AI assistant for Carlos, a Full Stack Developer.",
                "temperature": 0.3
        }}
    ],

    "connections": [
        {
            "from": "cost_predictor",
            "to": "router"
        },
        {
            "from": "router",
            "to": "reader"
        },
        {
            "from": "reader",
            "to": "llm"
        }
    ]
}